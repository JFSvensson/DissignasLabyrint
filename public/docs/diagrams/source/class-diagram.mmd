%% DissignasLabyrint - Class Diagram
%% Senast uppdaterad: 2026-03-26

classDiagram
    class MazeRenderer {
        -scene: Scene
        -camera: PerspectiveCamera
        -renderer: WebGLRenderer
        -mazeLogic: MazeLogic
        -questionText: Mesh
        -font: any
        -ui: GameUI
        +constructor(containerId: string, mazeLayout: number[][], mazeLogic: MazeLogic)
        -setupCamera(): void
        -initMaze(mazeLayout: number[][]): void
        -updateDirectionQuestions(questions: MazeQuestion[]): void
        -handleResize(): void
        +setUI(ui: GameUI): void
    }

    class Player {
        -mesh: Mesh
        -logic: PlayerLogic
        +constructor()
        +getMesh(): Mesh
        +getMazePosition(): MazePosition
        +move(direction: Direction): void
        +resetPosition(): void
    }

    class PlayerLogic {
        -currentPosition: Position3D
        -previousPosition: Position3D
        +constructor(startPosition: Position3D)
        +move(direction: Direction): void
        +resetPosition(): void
        +getMazePosition(): MazePosition
        +getCurrentPosition(): Position3D
    }

    class MazeLogic {
        -maze: MazeCell[][]
        -player: Player
        -goalPosition: MazePosition
        +constructor(mazeLayout: number[][], goalPosition?: MazePosition)
        +getQuestionsAtPosition(position: MazePosition): MazeQuestion[]
        +setQuestionForDirection(position: MazePosition, direction: Direction, question: string, answer: number): void
        +getAvailableDirections(position: MazePosition): Direction[]
        +movePlayer(direction: Direction): void
        +resetPlayerPosition(): void
        +updateAvailableDirections(): void
        +isGoalReached(position: MazePosition): boolean
        +getGoalPosition(): MazePosition
        +getPlayer(): Player
    }

    class MazeGenerator {
        +static generate(width: number, height: number): number[][]
        -static carve(maze: number[][], row: number, col: number, width: number, height: number): void
        -static shuffleDirections(): [number, number][]
    }

    class GameUI {
        -container: HTMLDivElement
        -questionDisplay: HTMLDivElement
        -answerInput: HTMLInputElement
        -directionButtons: Map~string, HTMLButtonElement~
        -messageDisplay: HTMLDivElement
        -languageSwitcher: HTMLDivElement
        -soundManager: SoundManager
        +constructor(containerId: string, onAnswer: Function, soundManager?: SoundManager)
        +updateQuestions(questions: Array): void
        +showFeedback(message: string, type: string): void
        +updateScore(score: number, attempts: number, streak: number): void
        +showVictoryScreen(score: number, attempts: number, accuracy: number, bestStreak: number, onPlayAgain: Function): void
        -createLanguageSwitcher(): HTMLDivElement
        -createSoundToggle(sm: SoundManager): HTMLDivElement
        -updateTranslations(): void
        -getActiveButton(): HTMLButtonElement
    }

    class QuestionGenerator {
        -static easyOperations: Operation[]
        -static allOperations: Operation[]
        +static generateQuestionsForMaze(mazeLogic: MazeLogic, mazeLayout: number[][]): void
        +static getDifficulty(position: MazePosition, mazeWidth: number, mazeHeight: number): number
        +static getMaxForDifficulty(difficulty: number): number
        +static getOperationsForDifficulty(difficulty: number): Operation[]
    }

    class ScoreTracker {
        -score: number
        -attempts: number
        -streak: number
        -bestStreak: number
        +recordAnswer(correct: boolean): void
        +getScore(): number
        +getAttempts(): number
        +getStreak(): number
        +getBestStreak(): number
        +getAccuracy(): number
        +reset(): void
    }

    class SoundManager {
        -ctx: AudioContext
        -enabled: boolean
        +setEnabled(enabled: boolean): void
        +isEnabled(): boolean
        +playCorrect(): void
        +playIncorrect(): void
        +playVictory(): void
        +playMove(): void
        -playTone(frequency: number, duration: number, type: OscillatorType, delay: number, volume: number): void
    }

    class TranslationService {
        -static instance: TranslationService
        -currentLocale: SupportedLocale
        -translations: Record
        -listeners: Set~Function~
        +static getInstance(): TranslationService
        +t(key: string): string
        +setLocale(locale: SupportedLocale): void
        +getLocale(): SupportedLocale
        +getSupportedLocales(): SupportedLocale[]
        +onChange(callback: Function): void
        +offChange(callback: Function): void
        -detectLocale(): SupportedLocale
        -notifyListeners(): void
    }

    class Operation {
        <<interface>>
        +calculate(a: number, b: number): number
        +formatQuestion(a: number, b: number): string
        +generateNumbers(max: number): [number, number]
        +getName(): string
    }

    class Addition {
        +calculate(a: number, b: number): number
        +formatQuestion(a: number, b: number): string
        +generateNumbers(max: number): [number, number]
        +getName(): string
    }

    class Subtraction {
        +calculate(a: number, b: number): number
        +formatQuestion(a: number, b: number): string
        +generateNumbers(max: number): [number, number]
        +getName(): string
    }

    class Multiplication {
        +calculate(a: number, b: number): number
        +formatQuestion(a: number, b: number): string
        +generateNumbers(max: number): [number, number]
        +getName(): string
    }

    class Division {
        +calculate(a: number, b: number): number
        +formatQuestion(a: number, b: number): string
        +generateNumbers(max: number): [number, number]
        +getName(): string
    }

    %% Interfaces och typer
    class MazeQuestion {
        <<interface>>
        +direction: Direction
        +question: string
        +answer: number
    }

    class MazeCell {
        <<interface>>
        +position: MazePosition
        +questions: MazeQuestion[]
        +isWall: boolean
    }

    class MazePosition {
        <<interface>>
        +x: number
        +z: number
    }

    class Position3D {
        <<interface>>
        +x: number
        +y: number
        +z: number
    }

    class Direction {
        <<enumeration>>
        NORTH
        SOUTH
        EAST
        WEST
    }

    %% Relationer
    MazeRenderer --> MazeLogic : renders
    MazeRenderer --> GameUI : updates
    MazeLogic --> Player : manages
    MazeLogic --> MazeCell : contains
    MazeLogic --|> EventEmitter : extends
    Player --> PlayerLogic : delegates to
    PlayerLogic --> Position3D : tracks
    PlayerLogic --> MazePosition : exposes
    MazeCell --> MazeQuestion : contains
    QuestionGenerator --> MazeLogic : populates
    QuestionGenerator --> Operation : uses
    GameUI --> SoundManager : plays sounds
    GameUI --> TranslationService : translates
    Addition ..|> Operation : implements
    Subtraction ..|> Operation : implements
    Multiplication ..|> Operation : implements
    Division ..|> Operation : implements
    MazeGenerator ..> MazeLogic : generates layout for