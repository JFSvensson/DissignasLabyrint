    %% Relationer
    MazeRenderer --> MazeLogic : renders
    MazeRenderer --> GameUI : updates
    MazeLogic --> Player : manages
    MazeLogic --> MazeCell : contains
    MazeLogic --|> EventEmitter : extends
    Player --> PlayerLogic : delegates to
    PlayerLogic --> Position3D : tracks
    PlayerLogic --> MazePosition : exposes
    MazeCell --> MazeQuestion : contains
    QuestionGenerator --> MazeLogic : populates
    QuestionGenerator --> Operation : uses
    QuestionGenerator --> GameConfig : reads MathDifficulty
    GameUI --> SoundManager : plays sounds
    GameUI --> TranslationService : translates
    GameUI --> GameTimer : displays
    StartScreen --> GameConfig : produces
    StartScreen --> TranslationService : translates
    StartScreen --> StatsManager : reads high scores
    StatsManager --> GameResult : manages
    StatsManager --> GameStats : persists to localStorage
    GameTimer --> TranslationService : translates
    Addition ..|> Operation : implements
    Subtraction ..|> Operation : implements
    Multiplication ..|> Operation : implements
    Division ..|> Operation : implements
    Modulo ..|> Operation : implements
    Power ..|> Operation : implements
    MazeGenerator ..> MazeLogic : generates layout for
    MazeRenderer --> PowerUpManager : renders power-ups
    PowerUpManager --> MazePosition : tracks

    class PowerUpManager {
        -powerUps: PowerUp[]
        -activeMultiplier: ActivePowerUp
        +placePowerUps(mazeLayout: number[][], count: number): void
        +getPowerUps(): PowerUp[]
        +getUncollectedPowerUps(): PowerUp[]
        +collectAtPosition(position: MazePosition): PowerUp
        +getScoreMultiplier(): number
        +consumeMultiplierUse(): void
        +getActiveMultiplier(): ActivePowerUp
        +getHintAnswer(questions: Array): Object
    }

    class ActivePowerUp {
        <<interface>>
        +type: PowerUpType
        +remaining: number
    }

    class PowerUp {
        <<interface>>
        +type: PowerUpType
        +position: MazePosition
        +collected: boolean
    }

    class PowerUpType {
        <<enumeration>>
        hint
        timeBonus
        scoreMultiplier
    }

    class Modulo {
        +calculate(a: number, b: number): number
        +formatQuestion(a: number, b: number): string
        +generateNumbers(max: number): [number, number]
        +getName(): string
    }

    class Power {
        +calculate(a: number, b: number): number
        +formatQuestion(a: number, b: number): string
        +generateNumbers(max: number): [number, number]
        +getName(): string
    }

    PowerUpManager --> PowerUp : manages
    PowerUpManager --> ActivePowerUp : tracks
    PowerUp --> PowerUpType : has type